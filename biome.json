{
    "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "files": {
        "ignoreUnknown": false,
        "includes": ["**", "!commitlint.config.js", "!biome.json"]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 100
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "double",
            "jsxQuoteStyle": "double"
        }
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": false,
            "style": {
                "useConst": "error",
                "useImportType": "error",
                "noNonNullAssertion": "off"
            },
            "suspicious": {
                "noExplicitAny": "off",
                "noEmptyBlock": "off"
            },
            "correctness": {
                "useExhaustiveDependencies": "warn"
            },
            "complexity": {
                "noImportantStyles": "off"
            },
            "a11y": {
                "noSvgWithoutTitle": "off",
                "noAmbiguousAnchorText": "off"
            }
        }
    },
    "json": {
        "formatter": {
            "enabled": true
        }
    },
    "css": {
        "formatter": {
            "enabled": true
        },
        "parser": {
            "tailwindDirectives": true
        }
    }
}
