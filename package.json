{
    "name": "portfolio",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "engines": {
        "node": ">=20.0.0"
    },
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "preview": "vite preview",
        "test": "vitest",
        "test:run": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "playwright test",
        "lint": "biome check",
        "format": "biome check --write",
        "prepare": "husky install"
    },
    "dependencies": {
        "gsap": "^3.15.0",
        "ogl": "^1.0.11",
        "react": "^19.2.7",
        "react-dom": "^19.2.7"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.5.3",
        "@commitlint/cli": "^21.2.1",
        "@commitlint/config-conventional": "^21.2.0",
        "@playwright/test": "^1.61.1",
        "@tailwindcss/postcss": "^4.3.2",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^24.13.2",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.3",
        "@vitest/coverage-v8": "^4.1.10",
        "autoprefixer": "^10.5.2",
        "husky": "^9.1.7",
        "jsdom": "^29.1.1",
        "lint-staged": "^17.0.8",
        "oxlint": "^1.71.0",
        "postcss": "^8.5.16",
        "tailwindcss": "^4.3.2",
        "typescript": "~6.0.2",
        "vite": "^8.1.1",
        "vitest": "^4.1.10"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "biome check --write"
        ],
        "*.{json,css,md}": [
            "biome check --write"
        ]
    }
}
